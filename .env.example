# ─────────────────────────────────────────────────────────────
# PSX Portfolio Tracker — Environment Variables
# Copy to .env.local and fill in real values.
# Until real values are added, the app runs in DEMO MODE with
# sample data so the full flow is navigable end-to-end.
# ─────────────────────────────────────────────────────────────

# Supabase (Postgres + Auth + RLS) — https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Server-only. Never expose this with NEXT_PUBLIC_ and never paste it into client code.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Upstash Redis (server-only price cache) — https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN

# Secret shared with Vercel Cron and the external cron scheduler.
# Send as `Authorization: Bearer <CRON_SECRET>` to:
# - /api/keep-alive
# - /api/cron/refresh
CRON_SECRET=change-me-to-a-long-random-string

# Public site URL (used for auth redirects). No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# PSX Data Portal base URL (override only if the source changes).
PSX_DPS_BASE_URL=https://dps.psx.com.pk
