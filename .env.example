# ─────────────────────────────────────────────────────────────
# PSX Portfolio Tracker — Environment Variables
# Copy to .env.local and fill in real values.
# Until real values are added, the app runs in DEMO MODE with
# sample data so the full flow is navigable end-to-end.
# ─────────────────────────────────────────────────────────────

# Supabase (Postgres + Auth + RLS) — https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Server-only. Never expose this with NEXT_PUBLIC_ and never paste it into client code.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Server-only Postgres connection string used by the deployment migration runner.
# Supabase Dashboard -> Project Settings -> Database -> Connection string -> URI.
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@YOUR_DB_HOST:5432/postgres?sslmode=require

# Upstash Redis (server-only price cache) — https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN

# Optional secondary Upstash Redis for larger public datasets such as fundamentals.
UPSTASH_REDIS_FALLBACK_REST_URL=https://YOUR-FALLBACK-DB.upstash.io
UPSTASH_REDIS_FALLBACK_REST_TOKEN=YOUR_FALLBACK_UPSTASH_TOKEN

# Secret shared with Vercel Cron and the external cron scheduler.
# Send as `Authorization: Bearer <CRON_SECRET>` to:
# - /api/keep-alive
# - /api/cron/refresh
CRON_SECRET=change-me-to-a-long-random-string

# Public site URL (used for auth redirects). No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Web Push notifications. Generate with:
# npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY
VAPID_SUBJECT=mailto:support@example.com

# PSX Data Portal base URL (override only if the source changes).
PSX_DPS_BASE_URL=https://dps.psx.com.pk

# Stock fundamentals API base URL override.
STOCK_FUNDAMENTALS_API_BASE_URL=https://your-fundamentals-api.example.com
