# ─────────────────────────────────────────────────────────────
# Stockli — Environment Variables
# Copy this file to `.env.local` for local development.
# `.env.example` keeps safe placeholders only.
# `.env.local` holds the real secrets and must stay private.
# ─────────────────────────────────────────────────────────────

# Public browser key: lets the frontend talk to Supabase Auth and public APIs.
# Safe for client-side use.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Server-only admin key: bypasses RLS for trusted server actions, cron jobs,
# and admin operations. Never expose this with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Server-only database connection string used by the migration runner during
# local scripts and production builds.
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@YOUR_DB_HOST:5432/postgres?sslmode=require

# Server-only Redis cache for prices and public datasets.
UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN

# Optional fallback Redis for larger public caches such as fundamentals.
UPSTASH_REDIS_FALLBACK_REST_URL=https://YOUR-FALLBACK-DB.upstash.io
UPSTASH_REDIS_FALLBACK_REST_TOKEN=YOUR_FALLBACK_UPSTASH_TOKEN

# Server-only cron secret used to protect keep-alive and refresh routes.
CRON_SECRET=change-me-to-a-long-random-string

# Public site URL used by auth redirects in the current environment.
# Development should stay on localhost:3001.
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Server-only Supabase Management API values used to push hosted auth email
# settings, SMTP, and branded templates with `npm run supabase:auth-email:apply`.
SUPABASE_PROJECT_REF=your_project_ref
SUPABASE_ACCESS_TOKEN=sbp_your_supabase_personal_access_token

# Server-only Brevo SMTP settings used by hosted Supabase Auth emails.
# These power signup confirmations, password resets, and password-changed notices.
SUPABASE_AUTH_SMTP_HOST=smtp-relay.brevo.com
SUPABASE_AUTH_SMTP_PORT=587
SUPABASE_AUTH_SMTP_USER=your_brevo_smtp_login
SUPABASE_AUTH_SMTP_PASS=your_brevo_smtp_key
SUPABASE_AUTH_SMTP_ADMIN_EMAIL=no-reply@example.com
SUPABASE_AUTH_SMTP_SENDER_NAME=Stockli

# Hosted Supabase auth email hourly rate limit once custom SMTP is enabled.
SUPABASE_AUTH_RATE_LIMIT_EMAIL_SENT=30

# Public + server push notification keys.
# Generate with: `npx web-push generate-vapid-keys`
NEXT_PUBLIC_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY
VAPID_SUBJECT=mailto:support@example.com

# Public market data source override used by the PSX adapters.
PSX_DPS_BASE_URL=https://dps.psx.com.pk

# Public fundamentals API override used by fundamentals fetchers.
STOCK_FUNDAMENTALS_API_BASE_URL=https://your-fundamentals-api.example.com

# Server-only AI provider key for stock analyzer insights.
ZAI_API_KEY=YOUR_ZAI_API_KEY
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
