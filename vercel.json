{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/keep-alive",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/refresh",
      "schedule": "15,30,45 4 * * 1-4"
    },
    {
      "path": "/api/cron/refresh",
      "schedule": "*/15 5-10 * * 1-4"
    },
    {
      "path": "/api/cron/refresh",
      "schedule": "*/15 4-7 * * 5"
    },
    {
      "path": "/api/cron/refresh",
      "schedule": "15,30,45 9 * * 5"
    },
    {
      "path": "/api/cron/refresh",
      "schedule": "*/15 10-11 * * 5"
    },
    {
      "path": "/api/cron/refresh",
      "schedule": "30 11 * * *"
    },
    {
      "path": "/api/cron/fundamentals-archive?incomplete=1&limit=20",
      "schedule": "15 20 * * *"
    }
  ]
}
